# ─────────────────────────────────────────────────
#  BOOGA WAR LOGS BOT — Environment Variables
# ─────────────────────────────────────────────────

# Your Discord Bot Token (from Discord Developer Portal)
BOT_TOKEN=your_bot_token_here

# Your Bot's Application/Client ID (from Discord Developer Portal)
CLIENT_ID=your_client_id_here

# [Optional] Your Discord Server/Guild ID
# Fill this in for INSTANT slash command registration (for testing)
# Leave blank to register globally (can take up to 1 hour)
GUILD_ID=your_guild_id_here

# Set to "true" automatically on Render; keeps the bot alive
# RENDER=true  ← Render sets this automatically, don't change it
